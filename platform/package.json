{
  "name": "vantix-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push",
    "stripe:setup": "node scripts/setup-stripe.js",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "generate": "node generator/generate.js",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "services:up": "docker compose up -d grafana prometheus",
    "services:down": "docker compose down",
    "dev:full": "concurrently \"npm run dev\" \"npm run stripe:listen\"",
    "db:seed": "node scripts/seed-demo.js",
    "onboard": "node scripts/onboard-client.js",
    "setup": "npm install && npx supabase start && npx supabase db reset && node scripts/seed-demo.js && docker compose up -d && echo \"✅ Ready! Open http://localhost:3000\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "check-i18n": "node scripts/check-i18n.js"
  },
  "dependencies": {
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.47.0",
    "date-fns": "^4.1.0",
    "docx": "^9.1.1",
    "dotenv": "^16.4.0",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "next-intl": "^4.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "resend": "^6.9.4",
    "stripe": "^17.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  }
}
