{
  "title": "PostgreSQL Performance — Vantix",
  "uid": "vantix-pg",
  "tags": ["vantix", "postgresql", "database"],
  "editable": true, "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    { "title": "Active Connections", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "pg_stat_activity_count{state=\"active\"}", "legendFormat": "Active" },
        { "expr": "pg_stat_activity_count{state=\"idle\"}", "legendFormat": "Idle" },
        { "expr": "pg_settings_max_connections", "legendFormat": "Max" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } } },
    { "title": "HikariCP Pool Usage", "type": "gauge", "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "hikaricp_connections_active / hikaricp_connections_max * 100" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] } } } },
    { "title": "Pool Active / Idle / Pending", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "Active" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "Idle" },
        { "expr": "hikaricp_connections_pending", "legendFormat": "Pending" }
      ] },
    { "title": "Cache Hit Ratio (%)", "type": "stat", "gridPos": { "h": 3, "w": 3, "x": 18, "y": 0 },
      "targets": [{ "expr": "pg_stat_database_blks_hit / (pg_stat_database_blks_hit + pg_stat_database_blks_read) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 95 }, { "color": "green", "value": 99 }] } } } },
    { "title": "TPS (Commits/s)", "type": "stat", "gridPos": { "h": 3, "w": 3, "x": 21, "y": 0 },
      "targets": [{ "expr": "rate(pg_stat_database_xact_commit[5m])" }],
      "fieldConfig": { "defaults": { "unit": "ops" } } },
    { "title": "Transactions per Second", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit[5m])", "legendFormat": "Commits/s" },
        { "expr": "rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "Rollbacks/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } } },
    { "title": "Connection Pool Wait Time (ms)", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "targets": [{ "expr": "hikaricp_connections_acquire_duration_seconds{quantile=\"0.95\"} * 1000", "legendFormat": "p95 acquire time" }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 500 }] } } } },
    { "title": "Lock Waits", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "targets": [{ "expr": "pg_locks_count{mode=\"ExclusiveLock\"}", "legendFormat": "Exclusive Locks" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }] } } } },
    { "title": "Slow Queries (>100ms) / min", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "rate(pg_stat_statements_calls{mean_exec_time_ms>100}[5m]) * 60", "legendFormat": "slow queries/min" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#C0392B" }, "custom": { "fillOpacity": 20 } } } },
    { "title": "Dead Tuples (needs VACUUM)", "type": "table", "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "topk(10, pg_stat_user_tables_n_dead_tup)", "format": "table" }] }
  ]
}
