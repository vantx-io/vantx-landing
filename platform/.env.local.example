# ═══ Supabase (desde `npx supabase start`) ═══
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # copiar de supabase start output
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # copiar de supabase start output

# ═══ Stripe (test mode — https://dashboard.stripe.com/test/apikeys) ═══
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx        # desde stripe listen
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (crear con: npm run stripe:setup)
STRIPE_PRICE_RETAINER_US=price_xxx
STRIPE_PRICE_RETAINER_LATAM=price_xxx
STRIPE_PRICE_CHECKUP_US=price_xxx
STRIPE_PRICE_CHECKUP_LATAM=price_xxx

# ═══ Grafana (local) ═══
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
GRAFANA_ADMIN_PASSWORD=vantix2026

# ═══ Grafana Cloud (onboarding — opcional, se omite si vacio) ═══
GRAFANA_CLOUD_API_KEY=            # Service Account token de grafana.com
GRAFANA_CLOUD_ORG_SLUG=           # slug de tu org en grafana.com (ej: vantxio)

# ═══ Slack (onboarding — opcional, se omite si vacio) ═══
SLACK_BOT_TOKEN=                  # xoxb-... Bot con scopes: channels:manage, chat:write

# ═══ Upstash Redis (rate limiting) ═══
UPSTASH_REDIS_REST_URL=               # from Upstash console → Redis → REST API
UPSTASH_REDIS_REST_TOKEN=             # from Upstash console → Redis → REST API

# ═══ App ═══
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Vantix Portal
